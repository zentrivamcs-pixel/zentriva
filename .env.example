# Copy this file to .env.local and set your own values.

# Admin dashboard password — checked SERVER-SIDE by /api/admin/login.
# Never prefix this with REACT_APP_ (that would embed it in the JS bundle).
ADMIN_PASSWORD=LONG-WAY
# Secret used to sign admin/member session tokens. Any long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=49jadojodhahid0edoaoSDOS

# WhatsApp community group invite link shown after a successful submission.
REACT_APP_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/REPLACE_WITH_YOUR_INVITE_CODE

# Paystack keys — get these from https://dashboard.paystack.com/#/settings/developer
# The public key is safe to expose in the client bundle; the secret key is
# used server-side only and must never be prefixed with REACT_APP_.
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_test_replace_me
PAYSTACK_SECRET_KEY=sk_test_replace_me

# --- Transactional email (Resend) -------------------------------------------
# Email stays disabled until BOTH of these are set. Get an API key from
# https://resend.com and verify your sending domain (SPF/DKIM) first.
RESEND_API_KEY=
# Must be on your Resend-verified domain, e.g. "Zentriva <no-reply@zentriva.org>"
EMAIL_FROM=

# --- Inbound email (Resend "Inbound") ----------------------------------------
# Lets the app receive email (e.g. support@yourdomain.com) into the admin
# Inbox page. Setup: Resend dashboard -> your domain -> enable Inbound ->
# add the MX record it shows you. Then Webhooks -> Add Webhook -> point it
# at POST https://yourapp.com/api/inbox/receive, select only the
# "email.received" event, and paste the signing secret below.
RESEND_WEBHOOK_SECRET=

# Public site origin used in email links (portal login, password reset).
APP_BASE_URL=http://localhost:3000

# --- File uploads (Vercel Blob) ----------------------------------------------
# Passport/ID photos and bank-transfer payment proof are uploaded to Vercel
# Blob storage. Create a Blob store at https://vercel.com/dashboard → your
# project → Storage → Create Database → Blob, then link it to this project —
# Vercel sets BLOB_READ_WRITE_TOKEN automatically. For local dev, copy that
# token here (Storage → your Blob store → .env.local tab).
BLOB_READ_WRITE_TOKEN=
